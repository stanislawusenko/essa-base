{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "esModuleInterop": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "types": ["node", "vite/client"]
  },

  "include": ["src/**/*.ts", "scripts/**/*.ts", "**/*.d.ts"]
}
